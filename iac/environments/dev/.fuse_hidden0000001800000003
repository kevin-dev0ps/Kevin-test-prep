# Environment: dev  (project=zyl-elevator, environment=dev)
# Only terraform.tfvars differs between environments.

locals {
  tags = {
    Project     = var.project
    Environment = var.environment
    "Sub-Tag"   = var.sub_tag
  }
}

# ---- shared infrastructure (one of each) ----
module "vpc" {
  source      = "../../modules/vpc"
  project     = var.project
  environment = var.environment
  region      = var.region
  tags        = local.tags
}

module "alb" {
  source      = "../../modules/alb"
  project     = var.project
  environment = var.environment
  region      = var.region
  tags        = local.tags
}

