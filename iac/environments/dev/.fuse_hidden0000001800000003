}

# ---- application services (one per GitHub repo) ----
module "ecs_be" {
  source      = "../../modules/ecs-service"
  project     = var.project
  environment = var.environment
  component   = "be"
  region      = var.region
  image       = var.be_image
  cluster_arn = module.ecs.cluster_arn
  tags        = local.tags
}

